{
    "id": "ffmpeg-utils",
    "name": "FFmpeg Provider",
    "version": "1.0.8",
    "plugin_type": "utility",
    "author": "Trae",
    "description": "为其他插件提供 FFmpeg 二进制文件。",
    "description_en": "Provides FFmpeg binaries for other plugins.",
    "runtime": "native",
    "license": "MIT",
    "homepage": "https://github.com/dqsq2e2/ffmpeg-utils",
    "entry_point": "ffmpeg_utils.dll",
    "config_schema": {
        "type": "object",
        "properties": {
            "version_check": {
                "type": "boolean",
                "title": "Check Version",
                "description": "Verify FFmpeg version on startup",
                "default": true
            }
        }
    }
}
